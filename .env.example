# D1 Manager Environment Configuration
#
# How it works:
# - Development: Vite auto-loads .env.development (no config needed)
# - Production (Cloudflare): No .env file needed - uses window.location.origin automatically
# - Production (Docker): Use this file to configure your Docker deployment container
#
# === Cloudflare Credentials ===
# Cloudflare Account ID (dash.cloudflare.com/{ACCOUNT_ID}/...)
ACCOUNT_ID="your_cloudflare_account_id"

# API Token with D1 Edit permission (dash.cloudflare.com/profile/api-tokens)
API_KEY="your_cloudflare_api_token"

# === Zero Trust Authentication ===
# Your Cloudflare Zero Trust Team Domain
TEAM_DOMAIN="https://yourteam.cloudflareaccess.com"

# Cloudflare Access Application AUD tag
POLICY_AUD="your_cloudflare_access_aud_tag"

# === Server Configuration ===
# Port to run the server on (default: 8787)
# PORT=8787

# Node Environment (default: production)
# NODE_ENV="production"
